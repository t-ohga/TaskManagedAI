# Copy this file to .env.local.
# Choose one runtime case below before starting Compose.
# Base docker-compose.yml requires TASKMANAGEDAI_ENVIRONMENT to be set explicitly.

POSTGRES_USER=taskmanagedai
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=taskmanagedai
TZ=Asia/Tokyo

TASKMANAGEDAI_APP_VERSION=0.1.0
TASKMANAGEDAI_API_HOST=127.0.0.1
TASKMANAGEDAI_API_PORT=8000
TASKMANAGEDAI_ARQ_QUEUE_NAME=taskmanagedai:jobs
TASKMANAGEDAI_WORKER_CANCEL_CHANNEL=taskmanagedai:cancel

# -----------------------------------------------------------------------------
# Production case: VPS base Compose only
# -----------------------------------------------------------------------------
# Required for every production start. Set this in .env.local or in the command
# environment. Do not run production with the development/test case selected.
# P0 Redis is unauthenticated on the Docker internal network / 127.0.0.1 host
# publish boundary.
#
# TASKMANAGEDAI_ENVIRONMENT=production
# TASKMANAGEDAI_DATABASE_URL=postgresql+asyncpg://taskmanagedai:REPLACE_ME_STRONG_DB_PASSWORD@postgres:5432/taskmanagedai
# TASKMANAGEDAI_REDIS_URL=redis://redis:6379/0
# TASKMANAGEDAI_DEV_LOGIN_COOKIE_SECRET=REPLACE_ME_PRODUCTION_COOKIE_SECRET
# TASKMANAGEDAI_ALLOWED_HOSTS=["127.0.0.1","localhost","api"]
# TASKMANAGEDAI_CORS_ALLOWED_ORIGINS=[]

# -----------------------------------------------------------------------------
# Development case: local Compose with docker-compose.dev.yml
# -----------------------------------------------------------------------------
# docker-compose.dev.yml pins TASKMANAGEDAI_ENVIRONMENT=development for api and
# worker. Also set TASKMANAGEDAI_ENVIRONMENT=development in .env.local or command
# environment so Compose interpolation can satisfy the base required env check.
# TASKMANAGEDAI_DEV_LOGIN_TOKEN is required only in development/test because the
# backend disables /auth/dev-login in production.
#
# TASKMANAGEDAI_ENVIRONMENT=development
TASKMANAGEDAI_DATABASE_URL=postgresql+asyncpg://taskmanagedai:REPLACE_ME@postgres:5432/taskmanagedai
TASKMANAGEDAI_REDIS_URL=redis://redis:6379/0
TASKMANAGEDAI_DEV_LOGIN_COOKIE_SECRET=REPLACE_ME
TASKMANAGEDAI_DEV_LOGIN_TOKEN=REPLACE_ME
TASKMANAGEDAI_ALLOWED_HOSTS=["127.0.0.1","localhost","api","testserver"]
TASKMANAGEDAI_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:3900","http://localhost:3900"]

# -----------------------------------------------------------------------------
# Test case: pytest or isolated test containers
# -----------------------------------------------------------------------------
# TASKMANAGEDAI_ENVIRONMENT=test
# TASKMANAGEDAI_DATABASE_URL=postgresql+asyncpg://taskmanagedai:test-password@postgres:5432/taskmanagedai
# TASKMANAGEDAI_REDIS_URL=redis://redis:6379/0
# TASKMANAGEDAI_DEV_LOGIN_COOKIE_SECRET=test-cookie-secret
# TASKMANAGEDAI_DEV_LOGIN_TOKEN=test-dev-login-token
# TASKMANAGEDAI_ALLOWED_HOSTS=["testserver","127.0.0.1","localhost"]
# TASKMANAGEDAI_CORS_ALLOWED_ORIGINS=[]
