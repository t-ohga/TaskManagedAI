# Secrets — repo is PUBLIC, never commit secret material (SOPS-encrypted や否やに関わらず local-only)
# 正本: rules/secretbroker-boundary.md / DD-06。実 secret は SOPS+age で local 管理し repo に置かない。
config/secrets/
.sops.yaml
# age / private key / SOPS 復号出力 (defense-in-depth、誤 add を物理的に防ぐ)
*.agekey
age-key.txt
keys.txt
*.dec
id_rsa
id_ed25519
*.pem
*.key
*.p12
*.pfx

# Local databases
*.sqlite3
*.db

# System files
.DS_Store

# Claude Code hook state (session-local)
.claude/.hook-state/
.claude/worktrees/
# Claude harness local-only working files (handoff / codex task spec 等、PUBLIC repo へ commit しない)
.claude/local/

# Codex Quality Loop runtime state (local run ledgers and archives)
.codex/plans/

# Claude harness runtime lock (background session lock, auto-generated)
.claude/scheduled_tasks.lock


# Python build artifacts
*.egg-info/

# Next.js auto-generated type reference (Next.js writes "should not be edited")
frontend/next-env.d.ts

# TypeScript incremental build info (doc-only PR scope 保護、R2 P2R1 F-P2R1-015 反映)
*.tsbuildinfo
