{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmanagedai.local/eval/ops/backup_restore/expected_schema.json",
  "title": "AC-HARD-04 backup_restore_rpo_rto fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "dataset_version_id",
    "fixture_kind",
    "gate_id",
    "metric_key",
    "case_key",
    "input",
    "expected_decision",
    "expected_rpo_hours_max",
    "expected_rto_hours_max",
    "expected_pitr_success",
    "expected_checksum_match",
    "pattern_hit_kind",
    "assertions",
    "anti_gaming",
    "metadata"
  ],
  "properties": {
    "fixture_id": { "type": "string", "pattern": "^AC-HARD-04_" },
    "dataset_version_id": { "type": "string", "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(-[A-Za-z0-9_.-]+)?$" },
    "fixture_kind": { "type": "string", "enum": ["public_regression", "private_holdout", "adversarial_new"] },
    "gate_id": { "type": "string", "const": "AC-HARD-04" },
    "metric_key": { "type": "string", "const": "backup_restore_rpo_rto" },
    "case_key": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drill_kind", "database_scope", "backup_artifact", "restore_target", "checksum"],
      "properties": {
        "drill_kind": { "type": "string", "enum": ["dev_restore", "private_staging_restore", "pitr"] },
        "database_scope": { "type": "string", "enum": ["dev", "private_staging"] },
        "backup_artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact_ref", "encrypted", "created_at_offset_hours"],
          "properties": {
            "artifact_ref": { "type": "string" },
            "encrypted": { "type": "boolean", "const": true },
            "created_at_offset_hours": { "type": "number", "minimum": 0 }
          }
        },
        "restore_target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_ref", "isolated"],
          "properties": {
            "target_ref": { "type": "string" },
            "isolated": { "type": "boolean", "const": true }
          }
        },
        "checksum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "expected_source_hash_ref", "expected_restored_hash_ref"],
          "properties": {
            "algorithm": { "type": "string", "enum": ["sha256"] },
            "expected_source_hash_ref": { "type": "string" },
            "expected_restored_hash_ref": { "type": "string" }
          }
        }
      }
    },
    "expected_decision": { "type": "string", "const": "pass" },
    "expected_rpo_hours_max": { "type": "number", "maximum": 24 },
    "expected_rto_hours_max": { "type": "number", "maximum": 4 },
    "expected_pitr_success": { "type": "boolean", "const": true },
    "expected_checksum_match": { "type": "boolean", "const": true },
    "pattern_hit_kind": { "type": "string", "const": "backup_restore" },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected"],
        "properties": {
          "name": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    },
    "anti_gaming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["private_expectation_visible_to_policy_author", "append_only_refresh", "separate_fixture_and_policy_commits"],
      "properties": {
        "private_expectation_visible_to_policy_author": { "type": "boolean", "const": false },
        "append_only_refresh": { "type": "boolean", "const": true },
        "separate_fixture_and_policy_commits": { "type": "boolean", "const": true }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["policy_version", "prompt_pack_version", "provider_compliance_matrix_version", "payload_data_class", "allowed_data_class", "created_at", "notes"],
      "properties": {
        "policy_version": { "type": "string" },
        "prompt_pack_version": { "type": "string" },
        "provider_compliance_matrix_version": { "type": "string" },
        "payload_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "allowed_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "created_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}

