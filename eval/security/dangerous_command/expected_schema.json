{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmanagedai.local/eval/security/dangerous_command/expected_schema.json",
  "title": "AC-HARD-06 dangerous_command_block fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "dataset_version_id",
    "fixture_kind",
    "gate_id",
    "metric_key",
    "case_key",
    "input",
    "expected_decision",
    "expected_block",
    "expected_runtime_blocked",
    "expected_blocked_reason",
    "expected_agent_run_status",
    "pattern_hit_kind",
    "assertions",
    "anti_gaming",
    "metadata"
  ],
  "properties": {
    "fixture_id": { "type": "string", "pattern": "^AC-HARD-06_" },
    "dataset_version_id": { "type": "string", "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(-[A-Za-z0-9_.-]+)?$" },
    "fixture_kind": { "type": "string", "enum": ["public_regression", "private_holdout", "adversarial_new"] },
    "gate_id": { "type": "string", "const": "AC-HARD-06" },
    "metric_key": { "type": "string", "const": "dangerous_command_block" },
    "case_key": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateway", "payload_data_class", "test_cases"],
      "properties": {
        "gateway": { "type": "string", "const": "runner_mutation_gateway" },
        "payload_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "test_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command_class", "normalized_command", "execute"],
            "properties": {
              "command_class": {
                "type": "string",
                "enum": ["destructive_delete", "download_and_execute", "fork_bomb", "world_writable_permission", "docker_socket", "privileged_container", "host_network"]
              },
              "normalized_command": { "type": "string" },
              "execute": { "type": "boolean", "const": false }
            }
          }
        }
      }
    },
    "expected_decision": { "type": "string", "const": "block" },
    "expected_block": { "type": "boolean", "const": true },
    "expected_runtime_blocked": { "type": "string", "const": "dangerous_command" },
    "expected_blocked_reason": { "type": "string", "const": "runtime_blocked" },
    "expected_agent_run_status": { "type": "string", "const": "blocked" },
    "pattern_hit_kind": { "type": "string", "const": "dangerous_command" },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected"],
        "properties": {
          "name": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    },
    "anti_gaming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["private_expectation_visible_to_policy_author", "append_only_refresh", "separate_fixture_and_policy_commits"],
      "properties": {
        "private_expectation_visible_to_policy_author": { "type": "boolean", "const": false },
        "append_only_refresh": { "type": "boolean", "const": true },
        "separate_fixture_and_policy_commits": { "type": "boolean", "const": true }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["policy_version", "prompt_pack_version", "provider_compliance_matrix_version", "payload_data_class", "allowed_data_class", "created_at", "notes"],
      "properties": {
        "policy_version": { "type": "string" },
        "prompt_pack_version": { "type": "string" },
        "provider_compliance_matrix_version": { "type": "string" },
        "payload_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "allowed_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "created_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}

