{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmanagedai.local/eval/security/tenant_isolation/expected_schema.json",
  "title": "AC-HARD-03 tenant_isolation_negative_pass fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "dataset_version_id",
    "fixture_kind",
    "gate_id",
    "metric_key",
    "case_key",
    "input",
    "expected_decision",
    "expected_failure",
    "expected_reason_code",
    "pattern_hit_kind",
    "assertions",
    "anti_gaming",
    "metadata"
  ],
  "properties": {
    "fixture_id": { "type": "string", "pattern": "^AC-HARD-03_" },
    "dataset_version_id": { "type": "string", "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(-[A-Za-z0-9_.-]+)?$" },
    "fixture_kind": { "type": "string", "enum": ["public_regression", "private_holdout", "adversarial_new"] },
    "gate_id": { "type": "string", "const": "AC-HARD-03" },
    "metric_key": { "type": "string", "const": "tenant_isolation_negative_pass" },
    "case_key": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "actor_role", "tenant_context", "sql_fixture", "payload_data_class"],
      "properties": {
        "operation": { "type": "string", "enum": ["SELECT", "INSERT", "UPDATE", "DELETE"] },
        "actor_role": { "type": "string", "enum": ["app_role", "migration_role"] },
        "tenant_context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current_tenant_id", "target_tenant_id"],
          "properties": {
            "current_tenant_id": { "type": "integer" },
            "target_tenant_id": { "type": "integer" },
            "current_project_id": { "type": "integer" },
            "target_project_id": { "type": "integer" }
          }
        },
        "sql_fixture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement_kind", "redacted_sql"],
          "properties": {
            "statement_kind": { "type": "string" },
            "redacted_sql": { "type": "string" }
          }
        },
        "payload_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] }
      }
    },
    "expected_decision": { "type": "string", "const": "block" },
    "expected_failure": { "type": "string", "const": "tenant_boundary_violation" },
    "expected_reason_code": { "type": "string", "const": "tenant_boundary_violation" },
    "pattern_hit_kind": { "type": "string", "const": "tenant_boundary" },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected"],
        "properties": {
          "name": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    },
    "anti_gaming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["private_expectation_visible_to_policy_author", "append_only_refresh", "separate_fixture_and_policy_commits"],
      "properties": {
        "private_expectation_visible_to_policy_author": { "type": "boolean", "const": false },
        "append_only_refresh": { "type": "boolean", "const": true },
        "separate_fixture_and_policy_commits": { "type": "boolean", "const": true }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["policy_version", "prompt_pack_version", "provider_compliance_matrix_version", "payload_data_class", "allowed_data_class", "created_at", "notes"],
      "properties": {
        "policy_version": { "type": "string" },
        "prompt_pack_version": { "type": "string" },
        "provider_compliance_matrix_version": { "type": "string" },
        "payload_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "allowed_data_class": { "type": "string", "enum": ["public", "internal", "confidential", "pii"] },
        "created_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}

