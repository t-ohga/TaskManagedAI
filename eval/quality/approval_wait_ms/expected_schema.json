{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmanagedai.local/eval/quality/approval_wait_ms/expected_schema.json",
  "title": "AC-KPI-03 approval_wait_ms fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "dataset_version_id",
    "fixture_kind",
    "kpi_id",
    "metric_key",
    "case_key",
    "input",
    "expected_aggregate",
    "assertions",
    "anti_gaming",
    "metadata"
  ],
  "properties": {
    "fixture_id": { "type": "string", "pattern": "^AC-KPI-03_" },
    "dataset_version_id": { "type": "string", "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(-[A-Za-z0-9_.-]+)?$" },
    "fixture_kind": { "type": "string", "enum": ["public_regression", "private_holdout", "adversarial_new"] },
    "kpi_id": { "type": "string", "const": "AC-KPI-03" },
    "metric_key": { "type": "string", "const": "approval_wait_ms" },
    "case_key": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_approvals"],
      "properties": {
        "sample_approvals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requested_at", "status"],
            "properties": {
              "requested_at": { "type": "string", "format": "date-time" },
              "decided_at": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "status": {
                "type": "string",
                "enum": ["pending", "approved", "rejected", "expired", "invalidated"]
              }
            },
            "if": {
              "properties": {
                "status": { "enum": ["approved", "rejected"] }
              },
              "required": ["status"]
            },
            "then": {
              "required": ["decided_at"],
              "properties": {
                "decided_at": { "type": "string", "format": "date-time" }
              }
            },
            "else": {
              "properties": {
                "decided_at": { "type": "null" }
              }
            }
          }
        }
      }
    },
    "expected_aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_count", "median_ms"],
      "properties": {
        "sample_count": { "type": "integer", "minimum": 1 },
        "median_ms": { "type": "number", "minimum": 0 },
        "p95_ms": { "type": ["number", "null"], "minimum": 0 },
        "min_ms": { "type": ["number", "null"], "minimum": 0 },
        "max_ms": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 }
        }
      }
    },
    "anti_gaming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_expectation_visible_to_policy_author",
        "append_only_refresh",
        "separate_fixture_and_policy_commits"
      ],
      "properties": {
        "private_expectation_visible_to_policy_author": { "type": "boolean" },
        "append_only_refresh": { "type": "boolean" },
        "separate_fixture_and_policy_commits": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["created_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}

