{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmanagedai.local/eval/quality/cost_per_completed_task/expected_schema.json",
  "title": "AC-KPI-05 cost_per_completed_task fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "dataset_version_id",
    "fixture_kind",
    "kpi_id",
    "metric_key",
    "case_key",
    "input",
    "expected_aggregate",
    "assertions",
    "anti_gaming",
    "metadata"
  ],
  "properties": {
    "fixture_id": { "type": "string", "pattern": "^AC-KPI-05_" },
    "dataset_version_id": { "type": "string", "const": "ac-kpi-05-v2026.05.09-skeleton" },
    "fixture_kind": { "type": "string", "enum": ["public_regression", "private_holdout", "adversarial_new"] },
    "kpi_id": { "type": "string", "const": "AC-KPI-05" },
    "metric_key": { "type": "string", "const": "cost_per_completed_task" },
    "case_key": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_runs"],
      "properties": {
        "sample_runs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tenant_id",
              "project_id",
              "run_id",
              "status",
              "cost_usd",
              "tokens_input",
              "tokens_output"
            ],
            "properties": {
              "tenant_id": { "type": "integer", "minimum": 1 },
              "project_id": { "type": "integer", "minimum": 1 },
              "run_id": {
                "type": "string",
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "queued",
                  "gathering_context",
                  "running",
                  "generated_artifact",
                  "schema_validated",
                  "policy_linted",
                  "diff_ready",
                  "waiting_approval",
                  "blocked",
                  "provider_refused",
                  "provider_incomplete",
                  "validation_failed",
                  "repair_exhausted",
                  "completed",
                  "failed",
                  "cancelled"
                ]
              },
              "cost_usd": { "type": "number", "minimum": 0 },
              "tokens_input": { "type": "integer", "minimum": 0 },
              "tokens_output": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "expected_aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_completed_runs",
        "total_cost_usd",
        "cost_per_completed_task_usd",
        "threshold_usd",
        "threshold_passed"
      ],
      "properties": {
        "total_completed_runs": { "type": "integer", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 },
        "cost_per_completed_task_usd": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 0.5
        },
        "threshold_usd": { "type": "number", "const": 0.5 },
        "threshold_passed": { "type": "boolean", "const": true }
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 }
        }
      }
    },
    "anti_gaming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_expectation_visible_to_policy_author",
        "append_only_refresh",
        "separate_fixture_and_policy_commits"
      ],
      "properties": {
        "private_expectation_visible_to_policy_author": { "type": "boolean", "const": false },
        "append_only_refresh": { "type": "boolean", "const": true },
        "separate_fixture_and_policy_commits": { "type": "boolean", "const": true }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["created_at", "notes", "source", "currency"],
      "properties": {
        "created_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "source": { "type": "string" },
        "currency": { "type": "string", "const": "USD" }
      }
    }
  }
}

